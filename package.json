{
  "name": "codegraph-impact",
  "version": "0.1.0",
  "description": "Turn git diffs into CodeGraph-powered impact reports, test suggestions, and AI-agent context packs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevengeyue/codegraph-impact.git"
  },
  "homepage": "https://github.com/stevengeyue/codegraph-impact#readme",
  "bugs": {
    "url": "https://github.com/stevengeyue/codegraph-impact/issues"
  },
  "bin": {
    "codegraph-impact": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "codegraph",
    "mcp",
    "ai-agent",
    "codex",
    "claude-code",
    "cursor",
    "impact-analysis",
    "git-diff",
    "developer-tools"
  ],
  "author": "geyuejun <steven_ge_yue@126.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
